generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ClientUserRole {
  OWNER
  MEMBER
}

enum PlanTier {
  FREE
  PLUS
}

enum MemoryKind {
  SHORT_TERM
  LONG_TERM
  PROFILE
}

enum CrmEventType {
  CHAT_MESSAGE
  PROFILE_UPDATED
  MEMORY_CAPTURED
  SUMMARY_UPDATED
  LEAD_CAPTURED
}

model Client {
  id                  String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId             String?     @map("owner_id") @db.Uuid
  name                String
  slug                String      @unique
  assistantName       String?     @map("assistant_name")
  isSuspended         Boolean     @default(false) @map("is_suspended")
  canTakeAppointments Boolean     @default(true) @map("can_take_appointments")
  requireProfiling    Boolean     @default(false) @map("require_profiling")
  requireUserAuthForChat Boolean  @default(false) @map("require_user_auth_for_chat")
  systemPrompt        String?     @map("system_prompt")
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @updatedAt @map("updated_at")
  owner               User?       @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  members             ClientUser[]
  userAiSettings      UserAiSetting[]
  documents           Document[]
  chunks              Chunk[]
  conversations Conversation[]
  chatCustomers    ChatCustomer[]
  customerProfiles CustomerProfile[]
  memoryEntries    MemoryEntry[]
  conversationSummaries ConversationSummary[]
  crmEvents        CrmEvent[]
  leads             Lead[]
  appointments      Appointment[]
  quotes            Quote[]
  feedback          Feedback[]
  fileAssets        FileAsset[]
  products          Product[]

  @@index([ownerId])
  @@map("clients")
}

model User {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String        @unique
  name         String?
  emailVerified DateTime?    @map("email_verified")
  image        String?
  passwordHash String?       @map("password_hash")
  planTier     PlanTier      @default(FREE) @map("plan_tier")
  plusPurchasedAt DateTime?  @map("plus_purchased_at")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  sessions       UserSession[]
  authAccounts   Account[]
  authSessions   Session[]
  clients        Client[]
  memberships    ClientUser[]
  aiSettings     UserAiSetting[]

  @@map("users")
}

model ClientUser {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId      String         @map("client_id") @db.Uuid
  userId        String         @map("user_id") @db.Uuid
  role          ClientUserRole @default(MEMBER)
  lastChatLoginAt DateTime?    @map("last_chat_login_at")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clientId, userId])
  @@index([userId])
  @@index([clientId, role])
  @@map("client_users")
}

model UserAiSetting {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId             String   @map("client_id") @db.Uuid
  userId               String   @map("user_id") @db.Uuid
  aiProvider           String?  @map("ai_provider")
  openaiApiKey         String?  @map("openai_api_key")
  openaiChatModel      String?  @map("openai_chat_model")
  openaiEmbeddingModel String?  @map("openai_embedding_model")
  ollamaBaseUrl        String?  @map("ollama_base_url")
  ollamaChatModel      String?  @map("ollama_chat_model")
  ollamaEmbeddingModel String?  @map("ollama_embedding_model")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clientId, userId])
  @@index([userId])
  @@map("user_ai_settings")
}

model UserSession {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("user_sessions")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id") @db.Uuid
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("auth_accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id") @db.Uuid
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("auth_sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("auth_verification_tokens")
}

model Document {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId  String   @map("client_id") @db.Uuid
  title     String
  source    String?
  createdAt DateTime @default(now()) @map("created_at")

  client Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  chunks Chunk[]
  productKnowledge Product?

  @@index([clientId])
  @@map("documents")
}

model Chunk {
  id         String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId   String                     @map("client_id") @db.Uuid
  documentId String                     @map("document_id") @db.Uuid
  content    String
  metadata   Json?
  embedding  Unsupported("vector(1536)")
  createdAt  DateTime                   @default(now()) @map("created_at")

  client   Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([documentId])
  @@map("chunks")
}

model Conversation {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId         String   @map("client_id") @db.Uuid
  customerId       String?  @map("customer_id") @db.Uuid
  sessionId        String   @map("session_id")
  userMessage      String   @map("user_message")
  assistantMessage String   @map("assistant_message")
  createdAt        DateTime @default(now()) @map("created_at")
  memoryEntries    MemoryEntry[]

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  customer ChatCustomer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([clientId, sessionId])
  @@index([clientId, customerId])
  @@map("conversations")
}

model ChatCustomer {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId       String   @map("client_id") @db.Uuid
  name           String
  normalizedName String   @map("normalized_name")
  email          String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  lastSessionId  String?  @map("last_session_id")
  profile        CustomerProfile?
  memoryEntries  MemoryEntry[]
  summaries      ConversationSummary[]
  crmEvents      CrmEvent[]

  client        Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  conversations Conversation[]

  @@unique([clientId, normalizedName])
  @@index([clientId])
  @@index([clientId, email])
  @@map("chat_customers")
}

model CustomerProfile {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId          String   @map("client_id") @db.Uuid
  customerId        String   @unique @map("customer_id") @db.Uuid
  preferredLanguage String?  @map("preferred_language")
  timezone          String?
  company           String?
  jobTitle          String?  @map("job_title")
  stage             String?
  goals             Json?
  painPoints        Json?    @map("pain_points")
  traits            Json?
  communicationStyle String? @map("communication_style")
  profileSummary    String?  @map("profile_summary")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  client   Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  customer ChatCustomer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@map("customer_profiles")
}

model MemoryEntry {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId        String      @map("client_id") @db.Uuid
  customerId      String      @map("customer_id") @db.Uuid
  conversationId  String?     @map("conversation_id") @db.Uuid
  kind            MemoryKind
  content         String
  summary         String?
  importanceScore Float       @default(0.5) @map("importance_score")
  source          String?
  metadata        Json?
  lastUsedAt      DateTime?   @map("last_used_at")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  client       Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  customer     ChatCustomer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([clientId, customerId, kind])
  @@index([clientId, lastUsedAt])
  @@index([conversationId])
  @@map("memory_entries")
}

model ConversationSummary {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId          String   @map("client_id") @db.Uuid
  customerId        String?  @map("customer_id") @db.Uuid
  sessionId         String   @map("session_id")
  summary           String
  keyFacts          Json?    @map("key_facts")
  openLoops         Json?    @map("open_loops")
  sourceMessageCount Int     @default(0) @map("source_message_count")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  client   Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  customer ChatCustomer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@unique([clientId, sessionId])
  @@index([clientId, customerId])
  @@map("conversation_summaries")
}

model CrmEvent {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId    String       @map("client_id") @db.Uuid
  customerId  String?      @map("customer_id") @db.Uuid
  sessionId   String?      @map("session_id")
  type        CrmEventType
  title       String
  description String?
  payload     Json?
  occurredAt  DateTime     @default(now()) @map("occurred_at")
  createdAt   DateTime     @default(now()) @map("created_at")

  client   Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  customer ChatCustomer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([clientId, occurredAt])
  @@index([clientId, customerId, type])
  @@map("crm_events")
}

model Lead {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId  String   @map("client_id") @db.Uuid
  sessionId String?  @map("session_id")
  name      String
  firstName String?  @map("first_name")
  lastName  String?  @map("last_name")
  email     String?
  phone     String?
  website   String?
  productInterest String? @map("product_interest")
  interestType    String? @map("interest_type")
  city            String?
  message   String?
  purchaseIntentDetectedAt DateTime? @map("purchase_intent_detected_at")
  purchaseEmailSentAt      DateTime? @map("purchase_email_sent_at")
  purchaseEmailError       String?   @map("purchase_email_error")
  createdAt DateTime @default(now()) @map("created_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([clientId, sessionId])
  @@map("leads")
}

model Feedback {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId  String   @map("client_id") @db.Uuid
  sessionId String?  @map("session_id")
  rating    Int?
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@map("feedback")
}

model Appointment {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId     String   @map("client_id") @db.Uuid
  sessionId    String?  @map("session_id")
  fullName     String   @map("full_name")
  email        String?
  phone        String?
  scheduledFor DateTime @map("scheduled_for")
  timezone     String?
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([clientId, scheduledFor])
  @@index([clientId, sessionId])
  @@map("appointments")
}

model Quote {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId        String   @map("client_id") @db.Uuid
  sessionId       String?  @map("session_id")
  customerName    String   @map("customer_name")
  company         String
  city            String
  email           String
  phone           String
  support         String
  aiType          String   @map("ai_type")
  training        String
  customizations  String?
  setupInitial    Int      @map("setup_initial")
  monthlyCost     Int      @map("monthly_cost")
  trainingCost    Int      @map("training_cost")
  emailSentToCustomer Boolean @default(false) @map("email_sent_to_customer")
  emailSentToInternal Boolean @default(false) @map("email_sent_to_internal")
  emailError      String?  @map("email_error")
  createdAt       DateTime @default(now()) @map("created_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([clientId, sessionId])
  @@map("quotes")
}

model AppSetting {
  id                  Int      @id @default(1)
  singleton           String   @unique @default("default")
  aiProvider          String?  @map("ai_provider")
  openaiApiKey        String?  @map("openai_api_key")
  openaiChatModel     String?  @map("openai_chat_model")
  openaiEmbeddingModel String? @map("openai_embedding_model")
  ollamaBaseUrl       String?  @map("ollama_base_url")
  ollamaChatModel     String?  @map("ollama_chat_model")
  ollamaEmbeddingModel String? @map("ollama_embedding_model")
  appBaseUrl          String?  @map("app_base_url")
  easyvoxSystemPrompt String?  @map("easyvox_system_prompt")
  purchaseEmailEnabled Boolean  @default(false) @map("purchase_email_enabled")
  resendApiKey        String?  @map("resend_api_key")
  purchaseEmailFrom   String?  @map("purchase_email_from")
  purchaseEmailReplyTo String? @map("purchase_email_reply_to")
  purchaseEmailSubjectTemplate String? @map("purchase_email_subject_template")
  purchaseEmailBodyTemplate String? @map("purchase_email_body_template")
  purchaseIntentKeywords String? @map("purchase_intent_keywords")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}

model FileAsset {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId   String   @map("client_id") @db.Uuid
  sessionId  String?  @map("session_id")
  filename   String
  mimeType   String   @map("mime_type")
  sizeBytes  Int      @map("size_bytes")
  blobUrl    String   @map("blob_url")
  blobPath   String   @map("blob_path")
  createdAt  DateTime @default(now()) @map("created_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  productImages ProductImage[]

  @@index([clientId])
  @@index([clientId, sessionId])
  @@map("file_assets")
}

model Product {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId           String   @map("client_id") @db.Uuid
  slug               String
  title              String
  description        String
  price              Decimal  @db.Decimal(10, 2)
  discountPercent    Int      @default(0) @map("discount_percent")
  productUrl         String   @map("product_url")
  structuredOutput   Json     @map("structured_output")
  knowledgeDocumentId String? @unique @map("knowledge_document_id") @db.Uuid
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  client            Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  knowledgeDocument Document?    @relation(fields: [knowledgeDocumentId], references: [id], onDelete: SetNull)
  images            ProductImage[]

  @@unique([clientId, slug])
  @@index([clientId, createdAt])
  @@map("products")
}

model ProductImage {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId  String   @map("product_id") @db.Uuid
  fileAssetId String  @map("file_asset_id") @db.Uuid
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  fileAsset FileAsset @relation(fields: [fileAssetId], references: [id], onDelete: Cascade)

  @@unique([productId, fileAssetId])
  @@index([productId, sortOrder])
  @@index([fileAssetId])
  @@map("product_images")
}
