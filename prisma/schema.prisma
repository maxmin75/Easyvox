generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ClientUserRole {
  OWNER
  MEMBER
}

model Client {
  id                  String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId             String?     @map("owner_id") @db.Uuid
  name                String
  slug                String      @unique
  assistantName       String?     @map("assistant_name")
  canTakeAppointments Boolean     @default(true) @map("can_take_appointments")
  requireProfiling    Boolean     @default(false) @map("require_profiling")
  requireUserAuthForChat Boolean  @default(false) @map("require_user_auth_for_chat")
  systemPrompt        String?     @map("system_prompt")
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @updatedAt @map("updated_at")
  owner               User?       @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  members             ClientUser[]
  userAiSettings      UserAiSetting[]
  documents           Document[]
  chunks              Chunk[]
  conversations Conversation[]
  leads             Lead[]
  appointments      Appointment[]
  feedback          Feedback[]
  fileAssets        FileAsset[]

  @@index([ownerId])
  @@map("clients")
}

model User {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String        @unique
  name         String?
  emailVerified DateTime?    @map("email_verified")
  image        String?
  passwordHash String?       @map("password_hash")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  sessions       UserSession[]
  authAccounts   Account[]
  authSessions   Session[]
  clients        Client[]
  memberships    ClientUser[]
  aiSettings     UserAiSetting[]

  @@map("users")
}

model ClientUser {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId      String         @map("client_id") @db.Uuid
  userId        String         @map("user_id") @db.Uuid
  role          ClientUserRole @default(MEMBER)
  lastChatLoginAt DateTime?    @map("last_chat_login_at")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clientId, userId])
  @@index([userId])
  @@index([clientId, role])
  @@map("client_users")
}

model UserAiSetting {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId             String   @map("client_id") @db.Uuid
  userId               String   @map("user_id") @db.Uuid
  aiProvider           String?  @map("ai_provider")
  openaiApiKey         String?  @map("openai_api_key")
  openaiChatModel      String?  @map("openai_chat_model")
  openaiEmbeddingModel String?  @map("openai_embedding_model")
  ollamaBaseUrl        String?  @map("ollama_base_url")
  ollamaChatModel      String?  @map("ollama_chat_model")
  ollamaEmbeddingModel String?  @map("ollama_embedding_model")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clientId, userId])
  @@index([userId])
  @@map("user_ai_settings")
}

model UserSession {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("user_sessions")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id") @db.Uuid
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("auth_accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id") @db.Uuid
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("auth_sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("auth_verification_tokens")
}

model Document {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId  String   @map("client_id") @db.Uuid
  title     String
  source    String?
  createdAt DateTime @default(now()) @map("created_at")

  client Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  chunks Chunk[]

  @@index([clientId])
  @@map("documents")
}

model Chunk {
  id         String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId   String                     @map("client_id") @db.Uuid
  documentId String                     @map("document_id") @db.Uuid
  content    String
  metadata   Json?
  embedding  Unsupported("vector(1536)")
  createdAt  DateTime                   @default(now()) @map("created_at")

  client   Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([documentId])
  @@map("chunks")
}

model Conversation {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId         String   @map("client_id") @db.Uuid
  sessionId        String   @map("session_id")
  userMessage      String   @map("user_message")
  assistantMessage String   @map("assistant_message")
  createdAt        DateTime @default(now()) @map("created_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([clientId, sessionId])
  @@map("conversations")
}

model Lead {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId  String   @map("client_id") @db.Uuid
  sessionId String?  @map("session_id")
  name      String
  email     String?
  phone     String?
  website   String?
  message   String?
  purchaseIntentDetectedAt DateTime? @map("purchase_intent_detected_at")
  purchaseEmailSentAt      DateTime? @map("purchase_email_sent_at")
  purchaseEmailError       String?   @map("purchase_email_error")
  createdAt DateTime @default(now()) @map("created_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([clientId, sessionId])
  @@map("leads")
}

model Feedback {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId  String   @map("client_id") @db.Uuid
  sessionId String?  @map("session_id")
  rating    Int?
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@map("feedback")
}

model Appointment {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId     String   @map("client_id") @db.Uuid
  sessionId    String?  @map("session_id")
  fullName     String   @map("full_name")
  email        String?
  phone        String?
  scheduledFor DateTime @map("scheduled_for")
  timezone     String?
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([clientId, scheduledFor])
  @@index([clientId, sessionId])
  @@map("appointments")
}

model AppSetting {
  id                  Int      @id @default(1)
  singleton           String   @unique @default("default")
  aiProvider          String?  @map("ai_provider")
  openaiApiKey        String?  @map("openai_api_key")
  openaiChatModel     String?  @map("openai_chat_model")
  openaiEmbeddingModel String? @map("openai_embedding_model")
  ollamaBaseUrl       String?  @map("ollama_base_url")
  ollamaChatModel     String?  @map("ollama_chat_model")
  ollamaEmbeddingModel String? @map("ollama_embedding_model")
  appBaseUrl          String?  @map("app_base_url")
  purchaseEmailEnabled Boolean  @default(false) @map("purchase_email_enabled")
  resendApiKey        String?  @map("resend_api_key")
  purchaseEmailFrom   String?  @map("purchase_email_from")
  purchaseEmailReplyTo String? @map("purchase_email_reply_to")
  purchaseEmailSubjectTemplate String? @map("purchase_email_subject_template")
  purchaseEmailBodyTemplate String? @map("purchase_email_body_template")
  purchaseIntentKeywords String? @map("purchase_intent_keywords")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}

model FileAsset {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId   String   @map("client_id") @db.Uuid
  sessionId  String?  @map("session_id")
  filename   String
  mimeType   String   @map("mime_type")
  sizeBytes  Int      @map("size_bytes")
  blobUrl    String   @map("blob_url")
  blobPath   String   @map("blob_path")
  createdAt  DateTime @default(now()) @map("created_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([clientId, sessionId])
  @@map("file_assets")
}
