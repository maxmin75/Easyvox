generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  slug         String     @unique
  systemPrompt String?    @map("system_prompt")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  documents    Document[]
  chunks       Chunk[]
  conversations Conversation[]
  leads        Lead[]
  feedback     Feedback[]
  fileAssets   FileAsset[]

  @@map("clients")
}

model Document {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId  String   @map("client_id") @db.Uuid
  title     String
  source    String?
  createdAt DateTime @default(now()) @map("created_at")

  client Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  chunks Chunk[]

  @@index([clientId])
  @@map("documents")
}

model Chunk {
  id         String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId   String                     @map("client_id") @db.Uuid
  documentId String                     @map("document_id") @db.Uuid
  content    String
  metadata   Json?
  embedding  Unsupported("vector(1536)")
  createdAt  DateTime                   @default(now()) @map("created_at")

  client   Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([documentId])
  @@map("chunks")
}

model Conversation {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId         String   @map("client_id") @db.Uuid
  sessionId        String   @map("session_id")
  userMessage      String   @map("user_message")
  assistantMessage String   @map("assistant_message")
  createdAt        DateTime @default(now()) @map("created_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([clientId, sessionId])
  @@map("conversations")
}

model Lead {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId  String   @map("client_id") @db.Uuid
  name      String
  email     String
  message   String?
  createdAt DateTime @default(now()) @map("created_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@map("leads")
}

model Feedback {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId  String   @map("client_id") @db.Uuid
  sessionId String?  @map("session_id")
  rating    Int?
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@map("feedback")
}

model AppSetting {
  id                  Int      @id @default(1)
  singleton           String   @unique @default("default")
  aiProvider          String?  @map("ai_provider")
  openaiApiKey        String?  @map("openai_api_key")
  openaiChatModel     String?  @map("openai_chat_model")
  openaiEmbeddingModel String? @map("openai_embedding_model")
  ollamaBaseUrl       String?  @map("ollama_base_url")
  ollamaChatModel     String?  @map("ollama_chat_model")
  ollamaEmbeddingModel String? @map("ollama_embedding_model")
  appBaseUrl          String?  @map("app_base_url")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}

model FileAsset {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId   String   @map("client_id") @db.Uuid
  filename   String
  mimeType   String   @map("mime_type")
  sizeBytes  Int      @map("size_bytes")
  blobUrl    String   @map("blob_url")
  blobPath   String   @map("blob_path")
  createdAt  DateTime @default(now()) @map("created_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@map("file_assets")
}
